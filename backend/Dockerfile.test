FROM node:20-alpine

WORKDIR /app

# Install build dependencies for native modules
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code (без SSH ключей)
COPY . .

# Create data directory
RUN mkdir -p /data

# Expose port
EXPOSE 3000

# Start tests
CMD ["npm", "test"]
