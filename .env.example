# ClawPanel Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# JWT Configuration (REQUIRED)
# =============================================================================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-secret-key

# JWT TTL settings
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# =============================================================================
# OpenClaw Gateway Configuration (REQUIRED)
# =============================================================================
# Gateway WebSocket URL
# For Linux: ws://172.17.0.1:18789
# For macOS/Windows: ws://host.docker.internal:18789
GATEWAY_URL=ws://host.docker.internal:18789

# Gateway Authentication
# Use TOKEN for full permissions (required for chat)
# Get from: cat ~/.openclaw/openclaw.json | jq -r '.gateway.auth.token'
GATEWAY_TOKEN=your-gateway-token-here

# Legacy password auth (read-only, not recommended)
# GATEWAY_PASSWORD=your-gateway-password-here

# =============================================================================
# SSH Terminal Configuration (OPTIONAL)
# =============================================================================
# SSH connection for built-in terminal
SSH_HOST=host.docker.internal
SSH_USER=root
SSH_PORT=22
SSH_KEY_PATH=/root/.ssh/id_ed25519

# =============================================================================
# Database Configuration
# =============================================================================
SQLITE_PATH=/data/clawpanel.db

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# =============================================================================
# Node Environment
# =============================================================================
NODE_ENV=production
