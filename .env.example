# ClawPanel Environment Configuration

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# JWT Secret for token signing (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here

# OpenClaw Gateway Password
# This MUST match the password configured in ~/.openclaw/openclaw.json
# Located at: gateway.auth.password
# Generate with: openssl rand -base64 32
GATEWAY_PASSWORD=your-gateway-password-here

# =============================================================================
# GATEWAY CONNECTION
# =============================================================================

# OpenClaw Gateway WebSocket URL
# For Linux with Docker: ws://172.17.0.1:18789 or ws://host.docker.internal:18789
# For macOS/Windows: ws://host.docker.internal:18789
GATEWAY_URL=ws://host.docker.internal:18789

# =============================================================================
# SSH TERMINAL CONFIGURATION
# =============================================================================

# SSH connection settings for Web Terminal
# The terminal in ClawPanel connects to your host server via SSH
# to provide access to OpenClaw CLI commands

# SSH Host (default: host.docker.internal - connects to Docker host)
SSH_HOST=host.docker.internal

# SSH User (default: root)
SSH_USER=root

# SSH Port (default: 22)
SSH_PORT=22

# Path to SSH private key inside container
# Default key is generated during installation and copied to container
SSH_KEY_PATH=/root/.ssh/id_ed25519

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Node Environment (development/production)
NODE_ENV=production

# Database path inside container
SQLITE_PATH=/data/clawpanel.db

# Rate limiting (milliseconds)
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100

# Log level (debug/info/warn/error)
LOG_LEVEL=info

# =============================================================================
# NOTES
# =============================================================================

# 1. Gateway WebSocket Protocol
#    ClawPanel uses OpenClaw Gateway WebSocket protocol v3 for real-time
#    communication. The connection requires:
#    - Valid GATEWAY_PASSWORD matching openclaw.json
#    - Correct client.id and client.mode constants
#    - Challenge-response handshake
#
# 2. SSH Terminal Setup
#    SSH keys are automatically generated during installation (install.sh).
#    The public key is added to ~/.ssh/authorized_keys on the host.
#    The private key is copied to the backend container.
#
# 3. Troubleshooting Gateway Connection
#    Check logs: docker compose logs -f backend
#    Should see: "Gateway authentication successful"
#
# 4. Troubleshooting SSH Terminal
#    Test from container: docker compose exec backend ssh root@host.docker.internal echo OK
#    Check SSH server: sudo systemctl status ssh
#
# 5. Security
#    - Change JWT_SECRET from default!
#    - Keep GATEWAY_PASSWORD secret
#    - SSH keys are unique per installation
#    - Use HTTPS in production (place certs in nginx/ssl/)
