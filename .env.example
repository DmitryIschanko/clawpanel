# ===========================================
# ClawPanel Environment Configuration
# ===========================================

# JWT Secret (REQUIRED - generate with: openssl rand -hex 32)
# This is used for signing JWT tokens. Change in production!
JWT_SECRET=change-this-to-random-secret-key-in-production

# Node Environment
NODE_ENV=production

# ===========================================
# OpenClaw Gateway Configuration
# ===========================================

# Gateway WebSocket URL
# For Linux: ws://172.17.0.1:18789
# For macOS/Windows: ws://host.docker.internal:18789
GATEWAY_URL=ws://host.docker.internal:18789

# Gateway Authentication Token (REQUIRED)
# Generate token with: openssl rand -hex 32
# Must match gateway.auth.token in ~/.openclaw/openclaw.json
# Example: bb47b7dd98fd6e47f64f50a169a95d942fc89918e2db9da4
GATEWAY_TOKEN=your-gateway-token-here

# ===========================================
# SSH Terminal Configuration (Optional)
# ===========================================

# SSH server host (default: host.docker.internal)
SSH_HOST=host.docker.internal

# SSH username (default: root)
SSH_USER=root

# SSH port (default: 22)
SSH_PORT=22

# Path to SSH private key (default: /root/.ssh/id_ed25519)
# This key must be authorized on the SSH server
SSH_KEY_PATH=/root/.ssh/id_ed25519

# ===========================================
# Database Configuration
# ===========================================

# SQLite database file path
SQLITE_PATH=/data/clawpanel.db

# ===========================================
# Rate Limiting
# ===========================================

# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW=60000

# Maximum requests per window (default: 100)
RATE_LIMIT_MAX=100
